rules_version = '2';

// このファイルは Firebase Console → Firestore Database → Rules タブに貼り付けて公開してください。
// （Firebase CLI を使う場合は firebase deploy --only firestore:rules でも可）

service cloud.firestore {
  match /databases/{database}/documents {

    match /rankings/{doc} {
      // 全員読める（ランキング表示用）
      allow read: if true;

      // 作成は厳格なスキーマ＋値域チェックを通したものだけ
      allow create: if
        request.resource.data.keys().hasOnly(['name', 'score', 'difficulty', 'date'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 12
        && request.resource.data.score is int
        && request.resource.data.score >= 0
        && request.resource.data.score <= 99999999
        && request.resource.data.difficulty in ['easy', 'normal', 'hard', 'lunatic']
        && request.resource.data.date == request.time;

      // 一度書き込まれたスコアの書き換え・削除は全面禁止
      allow update, delete: if false;
    }

    // それ以外のコレクションへのアクセスは禁止
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
